#!/usr/bin/env python3
"""Persist NAS availability from a fixed commissioning baseline."""

import json
import os
import subprocess
import tempfile
import time
from datetime import datetime, timezone
from pathlib import Path


# The initial boot installed the NAS OS. Track availability from the first
# normal boot immediately afterward.
BASELINE = datetime(2026, 7, 8, 0, 30, 59, tzinfo=timezone.utc)
STATE_DIR = Path("/var/lib/nas-uptime")
STATE_FILE = STATE_DIR / "state.json"
STATUS_FILE = STATE_DIR / "status.json"
DATA_POOL_PATH = Path("/data")
DATA_POOL_SAMPLE_INTERVAL = 60 * 60
DATA_POOL_HISTORY_RETENTION = 30 * 24 * 60 * 60


def boot_id() -> str:
    return Path("/proc/sys/kernel/random/boot_id").read_text().strip().replace("-", "")


def boot_epoch() -> int:
    for line in Path("/proc/stat").read_text().splitlines():
        if line.startswith("btime "):
            return int(line.split()[1])
    raise RuntimeError("unable to determine current boot time")


def journal_seed(now: int, current_boot: str, current_boot_epoch: int) -> int:
    """Sum retained completed boots, then the current boot, from the baseline."""
    output = subprocess.check_output(
        ["journalctl", "--list-boots", "--no-pager", "--utc"], text=True
    )
    baseline_epoch = int(BASELINE.timestamp())
    total = 0
    first_record = True
    for line in output.splitlines()[1:]:
        fields = line.split()
        if len(fields) < 10:
            continue
        recorded_boot = fields[1]
        if recorded_boot == current_boot:
            continue
        try:
            start = int(
                subprocess.check_output(
                    ["date", "-d", " ".join(fields[3:6]), "+%s"], text=True
                )
            )
            end = int(
                subprocess.check_output(
                    ["date", "-d", " ".join(fields[7:10]), "+%s"], text=True
                )
            )
        except (IndexError, ValueError, subprocess.CalledProcessError):
            continue
        # The supplied commissioning time precedes the first retained journal
        # entry in its initial boot. Count that unlogged boot-start interval as
        # online instead of treating it as an outage.
        effective_start = baseline_epoch if first_record else max(start, baseline_epoch)
        total += max(0, end - effective_start)
        first_record = False
    total += max(0, now - max(current_boot_epoch, baseline_epoch))
    return total


def write_json(target: Path, value: dict) -> None:
    with tempfile.NamedTemporaryFile("w", dir=STATE_DIR, delete=False) as handle:
        json.dump(value, handle, sort_keys=True)
        handle.write("\n")
        temporary = handle.name
    os.chmod(temporary, 0o644)
    os.replace(temporary, target)


def data_pool_sample(now: int) -> dict:
    stats = os.statvfs(DATA_POOL_PATH)
    total_bytes = stats.f_blocks * stats.f_frsize
    available_bytes = stats.f_bavail * stats.f_frsize
    return {
        "timestamp": now,
        "total_bytes": total_bytes,
        "available_bytes": available_bytes,
        "used_bytes": total_bytes - available_bytes,
    }


def data_pool_history(state: dict, now: int) -> tuple[dict, list[dict]]:
    cutoff = now - DATA_POOL_HISTORY_RETENTION
    history = [
        sample
        for sample in state.get("data_pool_history", [])
        if isinstance(sample, dict) and int(sample.get("timestamp", 0)) >= cutoff
    ]
    current = data_pool_sample(now)
    if not history or now - int(history[-1]["timestamp"]) >= DATA_POOL_SAMPLE_INTERVAL:
        history.append(current)
    return current, history


def main() -> None:
    STATE_DIR.mkdir(mode=0o755, parents=True, exist_ok=True)
    now = int(time.time())
    baseline_epoch = int(BASELINE.timestamp())
    current_boot = boot_id()
    current_boot_epoch = boot_epoch()

    previous_state = json.loads(STATE_FILE.read_text()) if STATE_FILE.exists() else {}
    if previous_state:
        state = previous_state
        online_seconds = int(state["online_seconds"])
        previous_seen = int(state["last_seen_epoch"])
        if state["boot_id"] == current_boot:
            online_seconds += max(0, now - previous_seen)
        else:
            online_seconds += max(0, now - max(current_boot_epoch, baseline_epoch))
    else:
        online_seconds = journal_seed(now, current_boot, current_boot_epoch)

    data_pool, history = data_pool_history(previous_state, now)

    elapsed_seconds = max(0, now - baseline_epoch)
    online_seconds = min(online_seconds, elapsed_seconds)
    availability_ratio = online_seconds / elapsed_seconds if elapsed_seconds else 1.0
    state = {
        "baseline_epoch": baseline_epoch,
        "boot_id": current_boot,
        "last_seen_epoch": now,
        "online_seconds": online_seconds,
        "data_pool_history": history,
    }
    status = {
        "availability_display": f"{availability_ratio * 100:.3f}%",
        "availability_ratio": availability_ratio,
        "baseline": BASELINE.isoformat().replace("+00:00", "Z"),
        "current_boot_seconds": max(0, now - current_boot_epoch),
        "elapsed_seconds": elapsed_seconds,
        "online_seconds": online_seconds,
        "data_pool": {
            **data_pool,
            "history": history,
            "used_percent": round(data_pool["used_bytes"] / data_pool["total_bytes"] * 100, 3)
            if data_pool["total_bytes"]
            else 0,
        },
    }
    write_json(STATE_FILE, state)
    write_json(STATUS_FILE, status)


if __name__ == "__main__":
    main()
