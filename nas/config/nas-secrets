#!/usr/bin/env bash
set -euo pipefail

readonly CIPHER_DIR=/data/.secrets-encrypted
readonly PLAIN_DIR=/data/secrets
readonly LOCKED_SENTINEL=/var/lib/nas-secrets/locked

shopt -s nullglob
backing_mountpoints=(/mnt/disk*/pool/secrets)
shopt -u nullglob

(( ${#backing_mountpoints[@]} > 0 )) || {
  printf 'No backing mountpoint paths were found.\n' >&2
  exit 1
}

make_mountpoints() {
  local path
  for path in "${backing_mountpoints[@]}"; do
    if [[ -L "$path" ]]; then
      [[ "$(readlink -- "$path")" == "$LOCKED_SENTINEL" ]] || {
        printf 'Unexpected symlink at %s.\n' "$path" >&2
        return 1
      }
      rm -- "$path"
      mkdir -- "$path"
    elif [[ ! -d "$path" ]]; then
      printf 'Missing mountpoint path %s.\n' "$path" >&2
      return 1
    fi
    chmod g-s,u=rwx,go= "$path"
  done

  # mergerfs may briefly retain the prior symlink type during the transition.
  local attempt
  for attempt in {1..20}; do
    if [[ -d "$PLAIN_DIR" && ! -L "$PLAIN_DIR" ]] && stat "$PLAIN_DIR" >/dev/null 2>&1; then
      return 0
    fi
    sleep 0.1
  done
  printf 'Plaintext mountpoint did not become ready at %s.\n' "$PLAIN_DIR" >&2
  return 1
}

make_locked_sentinel() {
  local path
  for path in "${backing_mountpoints[@]}"; do
    if [[ ! -L "$path" ]] && [[ -n "$(find "$path" -mindepth 1 -print -quit)" ]]; then
      printf 'Refusing to lock: unexpected plaintext exists under %s.\n' "$path" >&2
      return 1
    fi
  done
  for path in "${backing_mountpoints[@]}"; do
    if [[ -L "$path" ]]; then
      continue
    fi
    rmdir -- "$path"
    ln -s -- "$LOCKED_SENTINEL" "$path"
  done
}

usage() {
  printf 'Usage: nas-secrets unlock|lock|status\n' >&2
  exit 2
}

case "${1:-}" in
  unlock)
    if mountpoint -q "$PLAIN_DIR"; then
      printf '%s is already unlocked.\n' "$PLAIN_DIR"
      exit 0
    fi
    [[ -f "$CIPHER_DIR/gocryptfs.conf" ]] || {
      printf 'Encrypted secrets are not initialized at %s.\n' "$CIPHER_DIR" >&2
      exit 1
    }
    [[ -d "$LOCKED_SENTINEL" ]] || {
      printf 'Locked sentinel is missing at %s.\n' "$LOCKED_SENTINEL" >&2
      exit 1
    }
    if ! make_mountpoints; then
      make_locked_sentinel || true
      exit 1
    fi
    if gocryptfs -q -ko noexec "$CIPHER_DIR" "$PLAIN_DIR"; then
      :
    else
      status=$?
      make_locked_sentinel || true
      exit "$status"
    fi
    ;;
  lock)
    if ! mountpoint -q "$PLAIN_DIR"; then
      printf '%s is already locked.\n' "$PLAIN_DIR"
      exit 0
    fi
    fusermount3 -u "$PLAIN_DIR"
    make_locked_sentinel
    printf '%s is locked.\n' "$PLAIN_DIR"
    ;;
  status)
    if mountpoint -q "$PLAIN_DIR"; then
      printf 'unlocked\n'
    else
      printf 'locked\n'
    fi
    ;;
  *) usage ;;
esac
