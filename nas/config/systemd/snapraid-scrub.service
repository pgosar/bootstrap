[Unit]
Description=SnapRAID rotating partial scrub
Documentation=man:snapraid(1)
RequiresMountsFor=/data /mnt/disk1 /mnt/disk2 /mnt/disk3 /mnt/parity
After=local-fs.target

[Service]
Type=oneshot
ExecStart=/usr/bin/snapraid scrub -p 12 -o 10
Nice=10
IOSchedulingClass=best-effort
IOSchedulingPriority=7

