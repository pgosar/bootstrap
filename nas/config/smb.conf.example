[global]
   workgroup = WORKGROUP
   server string = NAS
   security = user
   map to guest = Bad User
   interfaces = 127.0.0.1 192.168.1.196
   bind interfaces only = yes
   server min protocol = SMB2
   logging = systemd
   load printers = no
   disable spoolss = yes
   smb ports = 445

[media]
   path = /data/media
   browseable = yes
   read only = no
   valid users = @nas
   create mask = 0664
   directory mask = 0775

[personal]
   path = /data/personal
   browseable = yes
   read only = no
   valid users = @nas
   create mask = 0660
   directory mask = 0770

[torrents]
   path = /data/torrents
   browseable = yes
   read only = no
   valid users = @nas
   create mask = 0664
   directory mask = 0775

# Do not export /data/secrets. It is the manually unlocked gocryptfs plaintext
# view. Never mount decrypted secrets into Docker containers.

[replicas]
   path = /data/replicas
   browseable = yes
   read only = no
   valid users = @nas
   create mask = 0660
   directory mask = 0770

[backups]
   path = /data/backups
   browseable = yes
   read only = no
   valid users = @nas
   create mask = 0660
   directory mask = 0770

[staging]
   path = /data/staging
   browseable = yes
   read only = no
   valid users = @nas
   create mask = 0660
   directory mask = 0770
