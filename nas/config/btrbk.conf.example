# Example btrbk policy. Snapshots live outside the mergerfs pool.
# Edit retention before applying to a real NAS.

timestamp_format        long
snapshot_preserve_min   1h
snapshot_preserve       24h 30d
transaction_log         /var/log/btrbk.log
lockfile                /run/lock/btrbk.lock

volume /mnt/disk1
  snapshot_dir snapshots

  # pool contains the parity-protected media, personal, replicas, and
  # encrypted-secrets directories as ordinary directories.
  subvolume pool

  # Docker remains an independently managed nested subvolume.
  subvolume pool/docker

volume /mnt/disk2
  snapshot_dir snapshots

  # pool contains the parity-protected media, personal, replicas, and
  # encrypted-secrets directories as ordinary directories.
  subvolume pool

  # Docker remains an independently managed nested subvolume.
  subvolume pool/docker

volume /mnt/disk3
  snapshot_dir snapshots

  # pool contains the parity-protected media, personal, replicas, and
  # encrypted-secrets directories as ordinary directories.
  subvolume pool

  # Docker remains an independently managed nested subvolume.
  subvolume pool/docker

# Docker is snapshotted independently. Staging, downloads, appdata-bulk, and
# backups remain nested subvolumes and are intentionally omitted from btrbk.
