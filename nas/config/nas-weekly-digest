#!/usr/bin/env bash
set -euo pipefail

readonly STATE_DIR="${NAS_WEEKLY_DIGEST_STATE_DIR:-/var/lib/nas-weekly-report}"
readonly REPORT_DIR="${NAS_WEEKLY_DIGEST_REPORT_DIR:-$STATE_DIR/reports}"
readonly LOCK_FILE="${NAS_WEEKLY_DIGEST_LOCK_FILE:-/run/lock/nas-weekly-digest.lock}"
readonly LARGE_BYTES="${NAS_WEEKLY_DIGEST_LARGE_BYTES:-1073741824}"
readonly MAX_ITEMS="${NAS_WEEKLY_DIGEST_MAX_ITEMS:-8}"
readonly MERGERFS_MIN_FREE_BYTES="${NAS_WEEKLY_DIGEST_MIN_FREE_BYTES:-107374182400}"
readonly DISK_IMBALANCE_BYTES="${NAS_WEEKLY_DIGEST_IMBALANCE_BYTES:-107374182400}"
readonly PHOTO_ROOTS="${NAS_WEEKLY_DIGEST_PHOTO_ROOTS:-/data/photos /data/personal/Photos}"
readonly INBOX_ROOTS="${NAS_WEEKLY_DIGEST_INBOX_ROOTS:-/data/inbox /data/staging}"
readonly SNAPRAID_POOL_ROOTS="${NAS_WEEKLY_DIGEST_SNAPRAID_POOL_ROOTS:-/mnt/disk1/pool/media /mnt/disk2/pool/media /mnt/disk3/pool/media}"
readonly SNAPRAID_EXCLUDED_RELATIVE="${NAS_WEEKLY_DIGEST_SNAPRAID_EXCLUDED_RELATIVE:-torrents iso-mirror tdarr-test .transcode staging snapshots .snapshots '#recycle'}"
readonly NO_NOTIFY="${NAS_WEEKLY_DIGEST_NO_NOTIFY:-false}"
readonly RECENT_SUMMARY=/var/lib/nas-recent-files/latest-summary
readonly DUPLICATE_SUMMARY=/var/lib/nas-duplicate-report/latest-summary

mkdir -p "$STATE_DIR" "$REPORT_DIR" "$(dirname "$LOCK_FILE")"
exec 9>"$LOCK_FILE"
flock -n 9 || exit 0

tmp_dir="$(mktemp -d "${STATE_DIR}/.run.XXXXXX")"
trap 'rm -rf "$tmp_dir"' EXIT

existing_roots() {
  local root
  for root in $1; do
    [ -d "$root" ] && printf '%s\n' "$root"
  done
}

summary_value() {
  local file="$1" key="$2"
  [ -f "$file" ] || return 0
  awk -F= -v key="$key" '$1 == key {sub(/^[^=]*=/, ""); print; exit}' "$file"
}

make_manifest() {
  local roots="$1" output="$2" root
  : >"$output"
  while IFS= read -r root; do
    find "$root" -xdev -type f -printf '%p\t%T@\t%s\n' 2>/dev/null || true
  done < <(existing_roots "$roots") | LC_ALL=C sort -t $'\t' -k1,1 >"$output"
}

new_paths() {
  local previous="$1" current="$2" output="$3"
  if [ ! -f "$previous" ]; then
    : >"$output"
    return 0
  fi
  LC_ALL=C comm -13 <(cut -f1 "$previous" | LC_ALL=C sort) <(cut -f1 "$current" | LC_ALL=C sort) >"$output"
}

changed_paths() {
  local previous="$1" current="$2" output="$3"
  if [ ! -f "$previous" ]; then
    : >"$output"
    return 0
  fi
  awk -F '\t' '
    NR == FNR { old[$1] = $2 FS $3; next }
    { now = $2 FS $3; if (!($1 in old) || old[$1] != now) print }
  ' "$previous" "$current" >"$output"
}

format_manifest_paths() {
  local paths="$1" manifest="$2" output="$3"
  awk -F '\t' '
    NR == FNR { wanted[$1] = 1; next }
    ($1 in wanted) {
      bytes = $3 + 0
      value = bytes
      unit = "B"
      if (value >= 1024) { value /= 1024; unit = "KiB" }
      if (value >= 1024) { value /= 1024; unit = "MiB" }
      if (value >= 1024) { value /= 1024; unit = "GiB" }
      if (value >= 1024) { value /= 1024; unit = "TiB" }
      printf "- %.1f %s %s\n", value, unit, $1
    }
  ' "$paths" "$manifest" | sed -n "1,${MAX_ITEMS}p" >"$output"
}

count_files() {
  local roots="$1" root
  while IFS= read -r root; do
    find "$root" -xdev -type f -printf '.' 2>/dev/null || true
  done < <(existing_roots "$roots") | wc -c
}

large_new_files() {
  local current="$1" new="$2" output="$3"
  awk -F '\t' -v min="$LARGE_BYTES" '
    NR == FNR { wanted[$1] = 1; next }
    ($1 in wanted) && ($3 + 0 >= min) { print }
  ' "$new" "$current" | sort -t $'\t' -k3,3nr | sed -n "1,${MAX_ITEMS}p" >"$output"
}

populated_excluded_dirs() {
  local output="$1" pool relative path count
  : >"$output"
  for pool in $SNAPRAID_POOL_ROOTS; do
    for relative in $SNAPRAID_EXCLUDED_RELATIVE; do
      path="$pool/$relative"
      [ -d "$path" ] || continue
      count="$(find "$path" -xdev -type f 2>/dev/null | wc -l)"
      [ "$count" -gt 0 ] && printf '%s\t%s\n' "$count" "$path" >>"$output"
    done
  done
  sort -t $'\t' -k1,1nr "$output" -o "$output"
}

unit_result() {
  local unit="$1" result timestamp exit_status
  result="$(systemctl show "$unit" -p Result --value 2>/dev/null || true)"
  timestamp="$(systemctl show "$unit" -p ExecMainExitTimestamp --value 2>/dev/null || true)"
  exit_status="$(systemctl show "$unit" -p ExecMainStatus --value 2>/dev/null || true)"
  printf '%s: result=%s exit=%s finished=%s\n' "$unit" "${result:-unknown}" "${exit_status:-unknown}" "${timestamp:-never}"
}

timer_state() {
  local unit="$1" state next
  state="$(systemctl is-enabled "$unit" 2>/dev/null || true)"
  next="$(systemctl show "$unit" -p NextElapseUSecRealtime --value 2>/dev/null || true)"
  printf '%s: enabled=%s next=%s\n' "$unit" "${state:-unknown}" "${next:-unknown}"
}

storage_line() {
  local path="$1" usage
  usage="$(df -P -h "$path" 2>/dev/null | awk 'NR == 2 {print $3 "/" $2 " (" $5 ")"}')"
  printf '%s: %s\n' "$path" "${usage:-unavailable}"
}

btrfs_usage_line() {
  local path="$1" usage
  usage="$(btrfs filesystem usage -b "$path" 2>/dev/null | awk '
    function human(value, unit, idx) {
      unit = "B"; idx = 1
      while (value >= 1024 && idx < 5) {
        value /= 1024
        idx++
      }
      unit = (idx == 1 ? "B" : idx == 2 ? "KiB" : idx == 3 ? "MiB" : idx == 4 ? "GiB" : "TiB")
      return sprintf("%.1f %s", value, unit)
    }
    /Device size:/ { size = $3 }
    /^    Used:/ { used = $2 }
    /Free \(estimated\):/ { free = $3 }
    /Data ratio:/ { ratio = $3 }
    END {
      if (size == "") exit 1
      printf "size=%s used=%s free=%s data-ratio=%s", human(size), human(used), human(free), ratio
    }
  ' || true)"
  printf '%s: %s\n' "$path" "${usage:-unavailable}"
}

disk_health_line() {
  local path="$1" used free
  used="$(btrfs filesystem usage -b "$path" 2>/dev/null | awk '/^    Used:/ {print $2; exit}' || true)"
  free="$(df -B1 --output=avail "$path" 2>/dev/null | awk 'NR == 2 {print $1}' || true)"
  printf '%s\t%s\t%s\n' "$path" "${used:-0}" "${free:-0}"
}

photos_manifest="$tmp_dir/photos.manifest"
inbox_manifest="$tmp_dir/inbox.manifest"
appdata_manifest="$tmp_dir/appdata.manifest"
make_manifest "$PHOTO_ROOTS" "$photos_manifest"
make_manifest "$INBOX_ROOTS" "$inbox_manifest"
make_manifest "/data/docker/appdata" "$appdata_manifest"

photos_new="$tmp_dir/photos.new"
inbox_new="$tmp_dir/inbox.new"
appdata_changed="$tmp_dir/appdata.changed"
new_paths "$STATE_DIR/photos.manifest" "$photos_manifest" "$photos_new"
new_paths "$STATE_DIR/inbox.manifest" "$inbox_manifest" "$inbox_new"
changed_paths "$STATE_DIR/appdata.manifest" "$appdata_manifest" "$appdata_changed"

photos_items="$tmp_dir/photos.items"
inbox_items="$tmp_dir/inbox.items"
appdata_items="$tmp_dir/appdata.items"
large_items="$tmp_dir/large.items"
excluded_dirs="$tmp_dir/excluded.dirs"
format_manifest_paths "$photos_new" "$photos_manifest" "$photos_items"
format_manifest_paths "$inbox_new" "$inbox_manifest" "$inbox_items"
format_manifest_paths "$appdata_changed" "$appdata_manifest" "$appdata_items"
large_new_files "$photos_manifest" "$photos_new" "$large_items"
populated_excluded_dirs "$excluded_dirs"

disk_health="$tmp_dir/disk.health"
: >"$disk_health"
for disk in /mnt/disk1 /mnt/disk2 /mnt/disk3; do
  disk_health_line "$disk" >>"$disk_health"
done
disk_low_free="$tmp_dir/disk.low-free"
awk -F '\t' -v minimum="$MERGERFS_MIN_FREE_BYTES" '$3 < minimum {printf "%s free=%.1f GiB\n", $1, $3 / 1073741824}' "$disk_health" >"$disk_low_free"
disk_low_free_count="$(wc -l <"$disk_low_free")"
disk_imbalance_bytes="$(awk -F '\t' '
  NR == 1 {min = max = $2; next}
  {if ($2 < min) min = $2; if ($2 > max) max = $2}
  END {if (NR > 0) print max - min; else print 0}
' "$disk_health")"
disk_imbalance_gib="$(awk -v bytes="$disk_imbalance_bytes" 'BEGIN {printf "%.1f", bytes / 1073741824}')"
disk_imbalance_alert=0
[ "$disk_imbalance_bytes" -gt "$DISK_IMBALANCE_BYTES" ] && disk_imbalance_alert=1
btrfs_scrub_status="$tmp_dir/btrfs.scrub"
: >"$btrfs_scrub_status"
for disk in /mnt/disk1 /mnt/disk2 /mnt/disk3; do
  scrub_summary="$(btrfs scrub status "$disk" 2>/dev/null | awk '/Error summary:/ {line=$0; sub(/^[[:space:]]+/, "", line); gsub(/[[:space:]]+/, " ", line); print line; found=1} END {if (!found) print "status unavailable"}' || true)"
  printf '%s\t%s\n' "$disk" "$scrub_summary" >>"$btrfs_scrub_status"
done
btrfs_scrub_error_count="$(awk -F '\t' '$2 != "Error summary: no errors found" {count++} END {print count + 0}' "$btrfs_scrub_status")"

photos_count="$(wc -l <"$photos_new")"
inbox_count="$(wc -l <"$inbox_new")"
appdata_count="$(wc -l <"$appdata_changed")"
large_count="$(wc -l <"$large_items")"
excluded_count="$(wc -l <"$excluded_dirs")"
pending_count="$(count_files "$INBOX_ROOTS")"
missing_roots=""
for root in $PHOTO_ROOTS $INBOX_ROOTS; do
  [ -d "$root" ] || missing_roots+=" $root"
done

docker_bad="$tmp_dir/docker.bad"
docker ps -a --format '{{.Names}}\t{{.Status}}' 2>/dev/null |
  awk -F '\t' '$2 !~ /^Up / {print}' | sed -n "1,${MAX_ITEMS}p" >"$docker_bad" || true
docker_bad_count="$(docker ps -a --format '{{.Names}}\t{{.Status}}' 2>/dev/null | awk -F '\t' '$2 !~ /^Up / {count++} END {print count + 0}' || true)"
docker_log_errors="$tmp_dir/docker.log.errors"
: >"$docker_log_errors"
while IFS= read -r container; do
  [ -n "$container" ] || continue
  log_count="$(docker logs --since 168h --tail 500 "$container" 2>&1 |
    grep -Eic 'error|fatal|panic|critical|oom|out of memory|traceback|failed' || true)"
  [ "$log_count" -gt 0 ] && printf '%s\t%s\n' "$log_count" "$container" >>"$docker_log_errors"
done < <(docker ps --format '{{.Names}}' 2>/dev/null)
sort -t $'\t' -k1,1nr "$docker_log_errors" -o "$docker_log_errors"
docker_log_error_count="$(awk -F '\t' '{sum += $1} END {print sum + 0}' "$docker_log_errors")"

journal_units="$tmp_dir/journal.units"
journalctl --since '7 days ago' -p 0..3 -q -o json 2>/dev/null |
  jq -r '._SYSTEMD_UNIT // .SYSLOG_IDENTIFIER // "unknown"' |
  sort | uniq -c | sort -nr | sed -n "1,${MAX_ITEMS}p" >"$journal_units" || true
journal_error_count="$(journalctl --since '7 days ago' -p 0..3 -q --no-pager 2>/dev/null | wc -l || true)"
smartd_error_count="$(journalctl -u smartd.service --since '7 days ago' -q --no-pager 2>/dev/null |
  grep -Ei 'smart|self-test' |
  grep -Eiv 'not found in smartd database|changed from|enabled|opened|is smart capable|monitoring|started' |
  grep -Eic 'error|fail|critical|warning|alert' || true)"
oom_count="$(journalctl -k --since '7 days ago' -q --no-pager 2>/dev/null | grep -Eci 'out of memory|killed process' || true)"
failed_units="$tmp_dir/failed.units"
systemctl --failed --no-legend --no-pager 2>/dev/null | awk '{print $1}' | sed -n "1,${MAX_ITEMS}p" >"$failed_units" || true
failed_unit_count="$(systemctl --failed --no-legend --no-pager 2>/dev/null | awk 'NF {count++} END {print count + 0}' || true)"
backup_failures="$tmp_dir/backup.failures"
: >"$backup_failures"
for unit in btrbk.service snapraid-sync.service snapraid-scrub.service; do
  load_state="$(systemctl show "$unit" -p LoadState --value 2>/dev/null || true)"
  [ "$load_state" = "loaded" ] || continue
  result="$(systemctl show "$unit" -p Result --value 2>/dev/null || true)"
  [ "$result" = "success" ] || printf '%s result=%s\n' "$unit" "${result:-unknown}" >>"$backup_failures"
done
backup_failure_count="$(wc -l <"$backup_failures")"

secrets_state="locked/unavailable"
if mountpoint -q /data/secrets 2>/dev/null; then
  secrets_state="unlocked (review whether this is expected)"
elif [ -d /data/secrets ]; then
  secrets_state="locked"
fi

recent_baseline="$(summary_value "$RECENT_SUMMARY" baseline)"
recent_media="$(summary_value "$RECENT_SUMMARY" media)"
recent_isos="$(summary_value "$RECENT_SUMMARY" isos)"
recent_personal="$(summary_value "$RECENT_SUMMARY" personal)"
recent_inbox="$(summary_value "$RECENT_SUMMARY" inbox)"
recent_immich_images="$(summary_value "$RECENT_SUMMARY" immich_images)"
recent_report="$(summary_value "$RECENT_SUMMARY" report)"
recent_media="${recent_media:-0}"
recent_isos="${recent_isos:-0}"
recent_personal="${recent_personal:-0}"
recent_inbox="${recent_inbox:-0}"
recent_immich_images="${recent_immich_images:-0}"
recent_total=$((recent_media + recent_isos + recent_personal + recent_inbox + recent_immich_images))
duplicate_status="$(summary_value "$DUPLICATE_SUMMARY" status)"
duplicate_files="$(summary_value "$DUPLICATE_SUMMARY" redundant_files)"
duplicate_reclaimable="$(summary_value "$DUPLICATE_SUMMARY" reclaimable)"
duplicate_report="$(summary_value "$DUPLICATE_SUMMARY" report)"
duplicate_generated="$(summary_value "$DUPLICATE_SUMMARY" generated_at)"
duplicate_files="${duplicate_files:-0}"
duplicate_reclaimable="${duplicate_reclaimable:-pending}"

report="$REPORT_DIR/$(date +%Y-%m-%d).txt"
{
  printf 'NAS weekly digest — %s\n\n' "$(date --iso-8601=seconds)"
  printf 'Btrfs usage:\n'
  btrfs_usage_line /mnt/disk1
  btrfs_usage_line /mnt/disk2
  btrfs_usage_line /mnt/disk3
  storage_line /mnt/parity
  printf 'MergerFS minimum-free checks (100 GiB): %s disk(s) below threshold\n' "$disk_low_free_count"
  sed -n '1,8p' "$disk_low_free"
  printf 'Btrfs used-space imbalance across data disks: %s GiB (alert threshold: %.1f GiB)\n' "$disk_imbalance_gib" "$(awk -v bytes="$DISK_IMBALANCE_BYTES" 'BEGIN {printf "%.1f", bytes / 1073741824}')"
  printf 'Btrfs scrub status:\n'
  awk -F '\t' '{print "- " $1 ": " $2}' "$btrfs_scrub_status"
  printf '\nChanges:\n'
  printf 'New photo files: %s\n' "$photos_count"
  sed -n '1,8p' "$photos_items"
  printf 'New intake files: %s (currently pending: %s)\n' "$inbox_count" "$pending_count"
  sed -n '1,8p' "$inbox_items"
  printf 'Changed Docker appdata files: %s\n' "$appdata_count"
  sed -n '1,8p' "$appdata_items"
  printf 'New large photo files (>= 1 GiB): %s\n' "$large_count"
  awk -F '\t' '{print "- " $3 " " $1}' "$large_items"
  printf 'Recent files report: media +%s | ISOs +%s | Personal +%s | Inbox +%s | Immich images +%s\n' "$recent_media" "$recent_isos" "$recent_personal" "$recent_inbox" "$recent_immich_images"
  printf 'Recent files report path: %s\n' "${recent_report:-pending first run}"
  [ "$recent_baseline" = yes ] && printf 'Recent files baseline was initialized this week.\n'
  printf 'Duplicate analysis: status=%s | duplicate files=%s | reclaimable=%s\n' "${duplicate_status:-pending first monthly run}" "$duplicate_files" "$duplicate_reclaimable"
  printf 'Duplicate report path: %s\n' "${duplicate_report:-pending first monthly run}"
  [ -n "$duplicate_generated" ] && printf 'Duplicate analysis generated: %s\n' "$duplicate_generated"
  printf '\nProtection:\n'
  printf 'Configured intake roots currently containing files: %s\n' "$pending_count"
  printf 'Configured path(s) missing: %s\n' "${missing_roots:-none}"
  printf 'Populated SnapRAID-excluded pool directories: %s (review each; these are intentional exclusions only if documented)\n' "$excluded_count"
  awk -F '\t' '{print "- " $1 " files " $2}' "$excluded_dirs"
  printf 'Secrets view: %s\n' "$secrets_state"
  printf '\nBackup and parity:\n'
  unit_result btrbk.service
  unit_result snapraid-sync.service
  unit_result snapraid-scrub.service
  timer_state btrbk.timer
  timer_state snapraid-sync.timer
  timer_state snapraid-scrub.timer
  printf '\nDocker:\n'
  printf 'Containers not Up: %s\n' "$docker_bad_count"
  sed -n '1,8p' "$docker_bad"
  printf 'Log error-like lines (last 7 days): %s\n' "$docker_log_error_count"
  awk -F '\t' '{print "- " $1 " lines " $2}' "$docker_log_errors"
  printf '\nFailures:\n'
  printf 'Journal priority 0-3 lines in last 7 days: %s\n' "$journal_error_count"
  printf 'SMART alert/error lines in last 7 days: %s\n' "$smartd_error_count"
  printf 'Kernel OOM/killed-process lines in last 7 days: %s\n' "$oom_count"
  printf 'Currently failed systemd units: %s\n' "$failed_unit_count"
  printf 'Backup/parity failures: %s\n' "$backup_failure_count"
  sed -n '1,8p' "$backup_failures"
  sed -n '1,8p' "$failed_units"
  sed -n '1,8p' "$journal_units"
} >"$report"

baseline="no"
if [ ! -f "$STATE_DIR/photos.manifest" ] || [ ! -f "$STATE_DIR/inbox.manifest" ] || [ ! -f "$STATE_DIR/appdata.manifest" ]; then
  baseline="yes"
fi
cp "$photos_manifest" "$STATE_DIR/photos.manifest"
cp "$inbox_manifest" "$STATE_DIR/inbox.manifest"
cp "$appdata_manifest" "$STATE_DIR/appdata.manifest"
ln -sfn "$(basename "$report")" "$REPORT_DIR/latest.txt"
find "$REPORT_DIR" -maxdepth 1 -type f -name '20*.txt' -mtime +90 -delete

critical_alerts="$tmp_dir/critical.alerts"
: >"$critical_alerts"
[ "$smartd_error_count" -gt 0 ] && printf 'SMARTD: %s alert/error lines in the last 7 days\n' "$smartd_error_count" >>"$critical_alerts"
[ "$backup_failure_count" -gt 0 ] && printf 'BACKUP/PARITY: %s failed service result(s)\n' "$backup_failure_count" >>"$critical_alerts"
[ "$docker_log_error_count" -gt 0 ] && printf 'DOCKER LOGS: %s error-like line(s) across running containers\n' "$docker_log_error_count" >>"$critical_alerts"
[ "$oom_count" -gt 0 ] && printf 'KERNEL: %s OOM/killed-process line(s)\n' "$oom_count" >>"$critical_alerts"
[ "$failed_unit_count" -gt 0 ] && printf 'SYSTEMD: %s unit(s) currently failed\n' "$failed_unit_count" >>"$critical_alerts"
[ "$disk_low_free_count" -gt 0 ] && printf 'STORAGE: %s disk(s) below the 100 GiB mergerfs minimum-free threshold\n' "$disk_low_free_count" >>"$critical_alerts"
[ "$disk_imbalance_alert" -eq 1 ] && printf 'STORAGE: data-disk used-space imbalance is %s GiB\n' "$disk_imbalance_gib" >>"$critical_alerts"
[ "$btrfs_scrub_error_count" -gt 0 ] && printf 'BTRFS: scrub status needs attention on %s disk(s)\n' "$btrfs_scrub_error_count" >>"$critical_alerts"
critical_count="$(wc -l <"$critical_alerts")"

summary="$(cat <<EOF
📊 NAS WEEKLY DIGEST ($(date +%Y-%m-%d))
Changes: photos +$photos_count | intake +$inbox_count (pending $pending_count) | media +$recent_media | ISOs +$recent_isos | Personal +$recent_personal | Immich images +$recent_immich_images
Health: Docker not-Up $docker_bad_count | Docker log errors $docker_log_error_count | journal priority 0-3 $journal_error_count | disk imbalance ${disk_imbalance_gib} GiB
Protection: SnapRAID exclusions with files $excluded_count | secrets $secrets_state
Storage: Btrfs usage and parity capacity are in the local report
Full report: $report
EOF
)"
if [ "$baseline" = "yes" ]; then
  summary+=$'\nBaseline initialized; change counts become meaningful next week.'
fi

if [ "$NO_NOTIFY" = "true" ]; then
  if [ "$critical_count" -gt 0 ]; then
    printf '🚨 CRITICAL NAS ALERTS\n%s\n' "$(cat "$critical_alerts")"
  fi
  printf '%s\n' "$summary"
else
  if [ "$critical_count" -gt 0 ]; then
    /usr/local/sbin/nas-notify weekly-digest $'🚨 **CRITICAL NAS ALERTS**\n'"$(cat "$critical_alerts")"
  fi
  /usr/local/sbin/nas-notify weekly-digest "$summary"
fi
if [ "$critical_count" -gt 0 ] || [ "$photos_count" -gt 0 ] || [ "$inbox_count" -gt 0 ] || [ "$appdata_count" -gt 0 ] || [ "$docker_bad_count" -gt 0 ] || [ "$excluded_count" -gt 0 ] || [ "$recent_total" -gt 0 ]; then
  details="$(sed -n '1,70p' "$report")"
  if [ "$NO_NOTIFY" = "true" ]; then
    printf 'Details:\n%s\n' "$details"
  else
    /usr/local/sbin/nas-notify weekly-digest $'Details:\n'"$details"
  fi
fi
