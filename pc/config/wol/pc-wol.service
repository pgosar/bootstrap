[Unit]
Description=Arm the wired NIC for Wake-on-LAN
After=network-online.target
Wants=network-online.target
DefaultDependencies=no
Before=shutdown.target reboot.target halt.target poweroff.target

[Service]
Type=oneshot
RemainAfterExit=yes
EnvironmentFile=-/etc/default/pc-wol
ExecStart=/usr/local/sbin/pc-arm-wol
ExecStop=/usr/local/sbin/pc-arm-wol

[Install]
WantedBy=multi-user.target
